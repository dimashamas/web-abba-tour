<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= article.title %> — ABBA Tour</title>
    <script src="https://cdn.tailwindcss.com">
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800;14..32,900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        /* ── BASE ── */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: #f7faf9;
            color: #1e293b;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .main-wrapper {
            flex: 1;
        }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #e2e8f0;
        }
        ::-webkit-scrollbar-thumb {
            background: #15803d;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #166534;
        }

        /* ── NAVBAR ── */
        .navbar {
            transition: all 0.3s ease;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        }
        .navbar-scrolled {
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
        }

        /* ── BACK BUTTON ── */
        .back-btn {
            transition: all 0.3s ease;
        }
        .back-btn:hover {
            transform: translateX(-6px);
            color: #15803d;
        }

        /* ── ARTICLE HEADER ── */
        .article-header {
            position: relative;
            background: linear-gradient(135deg, #0a2e1a 0%, #1a4a2a 40%, #2d6a3f 100%);
            padding: 60px 0 50px;
            border-radius: 0 0 48px 48px;
            overflow: hidden;
        }
        .article-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.03) 0%, transparent 40%);
            pointer-events: none;
        }
        .article-header .floating-shapes span {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
            animation: floatShape 20s infinite ease-in-out alternate;
        }
        @keyframes floatShape {
            0% {
                transform: translate(0, 0) scale(1) rotate(0deg);
            }
            100% {
                transform: translate(40px, -60px) scale(1.2) rotate(20deg);
            }
        }

        .article-title {
            font-size: 2.4rem;
            line-height: 1.15;
            letter-spacing: -0.02em;
        }
        @media (min-width: 768px) {
            .article-title {
                font-size: 3.2rem;
            }
        }

        /* ── CONTENT PROSE ── */
        .prose-custom {
            font-size: 1.05rem;
            line-height: 1.9;
            color: #1e293b;
        }
        .prose-custom p {
            margin-bottom: 1.5rem;
        }
        .prose-custom h2 {
            font-size: 1.6rem;
            font-weight: 800;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
            color: #0a2e1a;
        }
        .prose-custom h3 {
            font-size: 1.3rem;
            font-weight: 700;
            margin-top: 2rem;
            margin-bottom: 0.8rem;
            color: #1a4a2a;
        }
        .prose-custom ul,
        .prose-custom ol {
            margin-bottom: 1.5rem;
            padding-left: 1.8rem;
        }
        .prose-custom li {
            margin-bottom: 0.4rem;
        }
        .prose-custom blockquote {
            border-left: 4px solid #15803d;
            padding-left: 1.5rem;
            margin: 1.8rem 0;
            font-style: italic;
            color: #475569;
            background: #f1f5f9;
            padding: 1.2rem 1.8rem;
            border-radius: 12px;
        }
        .prose-custom img {
            border-radius: 16px;
            margin: 1.8rem 0;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
        }

        /* ── AUTHOR CARD ── */
        .author-card {
            background: #f8fafc;
            border-radius: 20px;
            padding: 24px 28px;
            border: 1px solid #e9edf2;
            transition: all 0.3s ease;
        }
        .author-card:hover {
            border-color: #15803d40;
            box-shadow: 0 8px 24px rgba(21, 128, 61, 0.06);
        }

        /* ── SHARE BUTTONS ── */
        .share-btn {
            transition: all 0.3s ease;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.1rem;
            border: none;
            cursor: pointer;
        }
        .share-btn:hover {
            transform: scale(1.12);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        /* ── RELATED ARTICLES ── */
        .related-card {
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid #e9edf2;
            background: white;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .related-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.12);
            border-color: #15803d40;
        }
        .related-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .related-card:hover img {
            transform: scale(1.04);
        }

        /* ── FADE UP ANIMATION ── */
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            animation: fadeUp 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }
        .fade-up-d1 {
            animation-delay: 0.1s;
        }
        .fade-up-d2 {
            animation-delay: 0.2s;
        }
        .fade-up-d3 {
            animation-delay: 0.3s;
        }
        .fade-up-d4 {
            animation-delay: 0.4s;
        }
        @keyframes fadeUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── FOOTER ── */
        .footer-gradient {
            background: linear-gradient(135deg, #0a2e1a 0%, #0f3d22 100%);
        }

        /* ── FLOATING SHARE (desktop) ── */
        .floating-share {
            position: sticky;
            top: 100px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .floating-share .share-btn {
            width: 48px;
            height: 48px;
            font-size: 1.2rem;
            border-radius: 50%;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
        }
        @media (max-width: 1024px) {
            .floating-share {
                display: none;
            }
        }

        /* ── READING PROGRESS (opsional) ── */
        .progress-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #15803d, #22c55e);
            z-index: 999;
            width: 0%;
            transition: width 0.1s ease;
        }
    </style>
</head>
<body>

    <!-- ════════════════════════════════════════════ -->
    <!--  READING PROGRESS BAR                       -->
    <!-- ════════════════════════════════════════════ -->
    <div id="progressBar" class="progress-bar"></div>


    <!-- ════════════════════════════════════════════ -->
    <!--  NAVBAR                                     -->
    <!-- ════════════════════════════════════════════ -->
    <nav id="navbar" class="navbar fixed top-0 left-0 w-full z-50 py-3 px-4 md:px-8 transition-all duration-300">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <!-- Logo + Back -->
            <div class="flex items-center gap-4">
                <a href="/#artikel" class="back-btn flex items-center gap-2 text-gray-600 font-semibold text-sm md:text-base transition-colors">
                    <i class="fas fa-arrow-left text-green-700"></i>
                    <span class="hidden sm:inline">Kembali ke Artikel</span>
                    <span class="sm:hidden">Kembali</span>
                </a>
                <div class="hidden md:block w-px h-6 bg-gray-300/60"></div>
                 <!-- Logo -->
                <a href="/" class="flex items-center">
                    <img src="/assets/logo.png" alt="Logo ABBA Tour" class="h-12 w-auto object-contain">
                </a>
            </div>

            <!-- CTA kecil -->
            <a href="https://wa.me/6281234567890" target="_blank" class="flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-xs md:text-sm font-bold px-4 py-2 rounded-full transition shadow-lg shadow-green-600/20">
                <i class="fab fa-whatsapp"></i>
                <span class="hidden sm:inline">Hubungi Kami</span>
            </a>
        </div>
    </nav>


    <!-- ════════════════════════════════════════════ -->
    <!--  ARTICLE HEADER (HERO)                      -->
    <!-- ════════════════════════════════════════════ -->
    <header class="article-header mt-[68px]">
        <div class="floating-shapes absolute inset-0 overflow-hidden pointer-events-none">
            <span class="w-64 h-64 -top-20 -left-20 opacity-30"></span>
            <span class="w-96 h-96 bottom-10 -right-20 opacity-20" style="animation-delay:5s;"></span>
            <span class="w-40 h-40 top-1/3 left-1/2 opacity-10" style="animation-delay:10s;"></span>
        </div>

        <div class="max-w-4xl mx-auto px-4 md:px-8 relative z-10">
            <!-- Breadcrumb -->
            <div class="flex items-center gap-2 text-sm text-white/50 mb-4 fade-up">
                <a href="/" class="hover:text-white/80 transition">Beranda</a>
                <i class="fas fa-chevron-right text-[10px]"></i>
                <a href="/#artikel" class="hover:text-white/80 transition">Artikel</a>
                <i class="fas fa-chevron-right text-[10px]"></i>
                <span class="text-white/70 truncate max-w-[200px]"><%= article.title %></span>
            </div>

            <!-- Meta info -->
            <div class="flex flex-wrap items-center gap-4 text-white/70 text-sm mb-4 fade-up fade-up-d1">
                <span><i class="far fa-calendar-alt mr-1.5"></i> <%= article.createdAt.toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
                <span class="hidden sm:inline">•</span>
                <span><i class="far fa-clock mr-1.5"></i> <span id="readingTime">3</span> menit membaca</span>
                <span class="hidden sm:inline">•</span>
                <span><i class="fas fa-user mr-1.5"></i> Admin ABBA Tour</span>
            </div>

            <!-- Title -->
            <h1 class="article-title font-extrabold text-white leading-tight fade-up fade-up-d2">
                <%= article.title %>
            </h1>

            <!-- Deskripsi singkat jika ada -->
            <% if (article.excerpt) { %>
            <p class="text-white/70 text-lg max-w-2xl mt-4 fade-up fade-up-d3">
                <%= article.excerpt %>
            </p>
            <% } %>
        </div>
    </header>


    <!-- ════════════════════════════════════════════ -->
    <!--  MAIN CONTENT                               -->
    <!-- ════════════════════════════════════════════ -->
    <div class="main-wrapper px-4 md:px-8 py-10">

        <div class="max-w-5xl mx-auto relative">

            <!-- Layout: konten + floating share -->
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_80px] gap-8">

                <!-- KONTEN UTAMA -->
                <div class="min-w-0">

                    <!-- Gambar unggulan -->
                    <div class="rounded-3xl overflow-hidden shadow-xl mb-10 fade-up">
                        <img src="<%= article.image %>" alt="<%= article.title %>" class="w-full h-auto max-h-[500px] object-cover" />
                    </div>

                    <!-- Isi Artikel -->
                    <article class="bg-white rounded-3xl shadow-sm border border-gray-100/80 p-6 md:p-10 fade-up fade-up-d1">
                        <div class="prose max-w-none text-gray-700 text-lg leading-relaxed whitespace-pre-wrap">
                            <%= article.content %>
                        </div>
                    </article>

                    <!-- Author & Share (mobile/tablet) -->
                    <div class="mt-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 bg-white rounded-2xl border border-gray-100/80 p-6 md:p-8 shadow-sm fade-up fade-up-d2">

                        <!-- Author -->
                        <div class="flex items-center gap-4">
                            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-green-600 to-emerald-400 flex items-center justify-center text-white font-extrabold text-xl shadow-lg shadow-green-600/20">
                                AB
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800">Admin ABBA Tour</h4>
                                <p class="text-sm text-gray-500">Tim profesional siap membantu Anda</p>
                            </div>
                        </div>

                        <!-- Share buttons (mobile) -->
                        <div class="flex items-center gap-3">
                            <span class="text-sm text-gray-400 font-medium mr-1">Bagikan:</span>
                            <button onclick="shareArticle('facebook')" class="share-btn" style="background:#1877F2;"><i class="fab fa-facebook-f"></i></button>
                            <button onclick="shareArticle('twitter')" class="share-btn" style="background:#000000;"><i class="fab fa-x-twitter"></i></button>
                            <button onclick="shareArticle('whatsapp')" class="share-btn" style="background:#25D366;"><i class="fab fa-whatsapp"></i></button>
                            <button onclick="shareArticle('linkedin')" class="share-btn" style="background:#0A66C2;"><i class="fab fa-linkedin-in"></i></button>
                        </div>
                    </div>

                    <!-- CTA Konsultasi -->
                    <div class="mt-10 bg-gradient-to-r from-green-50 to-emerald-50/60 rounded-2xl p-6 md:p-8 border border-green-100/60 flex flex-col md:flex-row items-center justify-between gap-6 fade-up fade-up-d3">
                        <div>
                            <h4 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                                <i class="fas fa-hands-praying text-green-700"></i> Ingin Beribadah dengan Nyaman?
                            </h4>
                            <p class="text-gray-600 text-sm mt-1">Dapatkan konsultasi program Umroh & Haji Khusus terbaik.</p>
                        </div>
                        <a href="https://wa.me/6281234567890" target="_blank" class="flex-shrink-0 bg-green-600 hover:bg-green-700 text-white px-8 py-3.5 rounded-full font-bold shadow-lg shadow-green-600/25 hover:shadow-green-600/40 transition-all duration-300 flex items-center gap-2">
                            <i class="fab fa-whatsapp text-xl"></i> Hubungi Admin
                        </a>
                    </div>

                </div>

                <!-- FLOATING SHARE (desktop) -->
                <div class="hidden lg:block">
                    <div class="floating-share">
                        <span class="text-xs font-medium text-gray-400 text-center uppercase tracking-wider mb-1">Share</span>
                        <button onclick="shareArticle('facebook')" class="share-btn" style="background:#1877F2;"><i class="fab fa-facebook-f"></i></button>
                        <button onclick="shareArticle('twitter')" class="share-btn" style="background:#000000;"><i class="fab fa-x-twitter"></i></button>
                        <button onclick="shareArticle('whatsapp')" class="share-btn" style="background:#25D366;"><i class="fab fa-whatsapp"></i></button>
                        <button onclick="shareArticle('linkedin')" class="share-btn" style="background:#0A66C2;"><i class="fab fa-linkedin-in"></i></button>
                        <button onclick="copyLink()" class="share-btn" style="background:#64748B;"><i class="fas fa-link"></i></button>
                    </div>
                </div>

            </div>


            <!-- ════════════════════════════════════════ -->
            <!--  ARTIKEL TERKAIT                        -->
            <!-- ════════════════════════════════════════ -->
            <% 
               const hasRelated = (typeof relatedArticles !== 'undefined' && Array.isArray(relatedArticles) && relatedArticles.length > 0);
               if (hasRelated) { 
            %>
            <section class="mt-20 fade-up fade-up-d4">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-2xl font-extrabold text-gray-800">
                        <i class="fas fa-book-open text-green-600 mr-2"></i> Artikel Terkait
                    </h2>
                    <a href="/#artikel" class="text-sm text-green-700 font-semibold hover:underline">Lihat Semua →</a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <% relatedArticles.forEach(rel => { %>
                    <a href="/artikel/<%= rel._id %>" class="related-card block">
                        <img src="<%= rel.image %>" alt="<%= rel.title %>" loading="lazy" />
                        <div class="p-5">
                            <h4 class="font-bold text-gray-800 line-clamp-2 text-base"><%= rel.title %></h4>
                            <div class="flex items-center gap-3 mt-2 text-xs text-gray-400">
                                <span><i class="far fa-calendar-alt"></i> <%= rel.createdAt.toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) %></span>
                            </div>
                        </div>
                    </a>
                    <% }) %>
                </div>
            </section>
            <% } %>

        </div>
    </div>


    <!-- ════════════════════════════════════════════ -->
    <!--  FOOTER                                     -->
    <!-- ════════════════════════════════════════════ -->
    <footer class="footer-gradient text-white/80 py-8 px-4 border-t-4 border-green-600 mt-12">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-white font-extrabold text-xs backdrop-blur-sm border border-white/10">
                    AB
                </div>
                <span class="font-bold text-white">ABBA <span class="text-emerald-300">Tour</span></span>
                <span class="hidden md:inline text-white/30">|</span>
                <span class="text-white/50 text-xs md:text-sm">PT. Abu Bakar Berkah</span>
            </div>
            <p class="text-white/40 text-xs">&copy; 2026 — Melayani dengan Hati</p>
            <div class="flex gap-4 text-white/40">
                <a href="#" class="hover:text-white transition"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="hover:text-white transition"><i class="fab fa-instagram"></i></a>
                <a href="#" class="hover:text-white transition"><i class="fab fa-youtube"></i></a>
            </div>
        </div>
    </footer>


    <!-- ════════════════════════════════════════════ -->
    <!--  JAVASCRIPT                                 -->
    <!-- ════════════════════════════════════════════ -->
    <script>
        // ── READING PROGRESS BAR ──
        window.addEventListener('scroll', () => {
            const scrollTop = window.scrollY;
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            const progress = (scrollTop / docHeight) * 100;
            document.getElementById('progressBar').style.width = progress + '%';
        });

        // ── NAVBAR SCROLL ──
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            navbar.classList.toggle('navbar-scrolled', window.scrollY > 30);
        });

        // ── HITUNG WAKTU BACA (estimasi) ──
        (function calcReadingTime() {
            const content = document.querySelector('.prose-custom')?.textContent || '';
            const words = content.trim().split(/\s+/).length;
            const avgWpm = 220; // kata per menit
            const minutes = Math.max(1, Math.ceil(words / avgWpm));
            const el = document.getElementById('readingTime');
            if (el) el.textContent = minutes;
        })();

        // ── SHARE FUNCTIONS ──
        function shareArticle(platform) {
            const url = encodeURIComponent(window.location.href);
            const title = encodeURIComponent(document.querySelector('h1')?.textContent || 'ABBA Tour');
            let shareUrl = '';

            switch (platform) {
                case 'facebook':
                    shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
                    break;
                case 'twitter':
                    shareUrl = `https://twitter.com/intent/tweet?text=${title}&url=${url}`;
                    break;
                case 'whatsapp':
                    shareUrl = `https://api.whatsapp.com/send?text=${title}%20${url}`;
                    break;
                case 'linkedin':
                    shareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;
                    break;
                default:
                    return;
            }

            if (shareUrl) {
                window.open(shareUrl, '_blank', 'width=600,height=500');
            }
        }

        // ── COPY LINK ──
        function copyLink() {
            navigator.clipboard?.writeText(window.location.href).then(() => {
                // Feedback sederhana
                const btn = document.querySelector('.floating-share .share-btn:last-child');
                if (btn) {
                    const original = btn.innerHTML;
                    btn.innerHTML = '<i class="fas fa-check"></i>';
                    setTimeout(() => { btn.innerHTML = original; }, 2000);
                }
            }).catch(() => {
                alert('Salin link: ' + window.location.href);
            });
        }

        // ── SMOOTH SCROLL UNTUK ANCHOR ──
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                if (href === '#') return;
                e.preventDefault();
                const target = document.querySelector(href);
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>

</body>
</html>