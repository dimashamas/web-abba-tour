    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        /* ── BASE ── */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: #f7faf9;
            color: #1e293b;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .main-wrapper {
            flex: 1;
        }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #e2e8f0;
        }
        ::-webkit-scrollbar-thumb {
            background: #15803d;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #166534;
        }

        /* ── NAVBAR ── */
        .navbar {
            transition: all 0.3s ease;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        }
        .navbar-scrolled {
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
        }
        .nav-link {
            transition: color 0.3s ease;
            position: relative;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background: #15803d;
            transition: width 0.3s ease;
        }
        .nav-link:hover::after,
        .nav-link.active::after {
            width: 100%;
        }
        .nav-link.active {
            color: #15803d;
            font-weight: 700;
        }

        /* ── HERO ── */
        .hero-profile {
            position: relative;
            background: linear-gradient(135deg, #0a2e1a 0%, #1a4a2a 40%, #2d6a3f 100%);
            padding: 80px 0 70px;
            border-radius: 0 0 48px 48px;
            overflow: hidden;
        }
        .hero-profile::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.03) 0%, transparent 40%);
            pointer-events: none;
        }
        .hero-profile .floating-shapes span {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
            animation: floatShape 20s infinite ease-in-out alternate;
        }
        @keyframes floatShape {
            0% {
                transform: translate(0, 0) scale(1) rotate(0deg);
            }
            100% {
                transform: translate(40px, -60px) scale(1.2) rotate(20deg);
            }
        }
        .hero-title {
            font-size: 2.8rem;
            line-height: 1.1;
            letter-spacing: -0.02em;
        }
        @media (min-width: 768px) {
            .hero-title {
                font-size: 3.8rem;
            }
        }

        /* ── SECTION TITLE ── */
        .section-title {
            font-weight: 800;
            letter-spacing: -0.02em;
        }
        .section-underline {
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, #15803d, #22c55e);
            border-radius: 10px;
            margin: 16px auto 0;
        }

        /* ── CARD STYLES ── */
        .info-card {
            background: white;
            border-radius: 20px;
            padding: 24px 28px;
            border: 1px solid #e9edf2;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .info-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.08);
            border-color: #15803d40;
        }
        .info-card .icon-circle {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #15803d;
            font-size: 1.3rem;
            flex-shrink: 0;
        }

        /* ── TIMELINE ── */
        .timeline-item {
            position: relative;
            padding-left: 32px;
            padding-bottom: 32px;
            border-left: 2px solid #e2e8f0;
        }
        .timeline-item:last-child {
            border-left: none;
            padding-bottom: 0;
        }
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -8px;
            top: 4px;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #15803d;
            border: 3px solid #dcfce7;
        }
        .timeline-item .year {
            font-weight: 800;
            color: #15803d;
            font-size: 1.1rem;
        }

        /* ── LEGALITY TABLE ── */
        .legality-table {
            width: 100%;
            border-collapse: collapse;
        }
        .legality-table td {
            padding: 10px 16px;
            border-bottom: 1px solid #e9edf2;
        }
        .legality-table tr:last-child td {
            border-bottom: none;
        }
        .legality-table .label {
            font-weight: 600;
            color: #1e293b;
            width: 40%;
            background: #f8fafc;
        }
        .legality-table .value {
            color: #475569;
        }

        /* ── FADE UP ── */
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            animation: fadeUp 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }
        .fade-up-d1 {
            animation-delay: 0.1s;
        }
        .fade-up-d2 {
            animation-delay: 0.2s;
        }
        .fade-up-d3 {
            animation-delay: 0.3s;
        }
        .fade-up-d4 {
            animation-delay: 0.4s;
        }
        @keyframes fadeUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── FOOTER ── */
        .footer-gradient {
            background: linear-gradient(135deg, #0a2e1a 0%, #0f3d22 100%);
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 640px) {
            .hero-title {
                font-size: 2.2rem;
            }
            .info-card {
                padding: 20px;
            }
            .timeline-item {
                padding-left: 24px;
            }
        }
    </style>
</head>
