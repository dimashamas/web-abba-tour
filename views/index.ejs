<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PT. Abu Bakar Berkah - ABBA Tour</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        html { scroll-behavior: smooth; }
        .group-hover\:visible { visibility: visible; }
        .group-hover\:opacity-100 { opacity: 1; }
    </style>
</head>
<body class="bg-gray-50 font-sans">

    <nav class="bg-white shadow-md p-4 sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/" class="flex items-center">
                <img src="/assets/logo.png" alt="Logo ABBA Tour" class="h-12 w-auto object-contain">
            </a>
            <ul class="flex space-x-6 text-gray-600 font-medium hidden lg:flex items-center">
                <li><a href="#" class="hover:text-green-600 transition">Beranda</a></li>
                <li><a href="#profile" class="hover:text-green-600 transition">Profile</a></li>
                <li class="relative group pb-4 pt-4 -my-4">
                    <a href="#paket" class="hover:text-green-600 transition flex items-center cursor-pointer">
                        Paket dan Jadwal <i class="fas fa-chevron-down ml-1 text-xs"></i>
                    </a>
                    <div class="absolute left-0 mt-4 w-48 bg-white border border-gray-100 rounded-md shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50">
                        <div class="py-2">
                            <a href="#paket-umroh" class="block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-green-600">Paket Umroh</a>
                            <a href="#paket-haji" class="block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-green-600">Paket Haji Khusus</a>
                        </div>
                    </div>
                </li>
                <li><a href="#galeri" class="hover:text-green-600 transition">Galeri</a></li>
                <li><a href="#artikel" class="hover:text-green-600 transition">Artikel</a></li>
                <li><a href="#kontak" class="hover:text-green-600 transition">Hubungi Kami</a></li>
            </ul>
            <a href="#kontak" class="hidden lg:block bg-green-600 text-white px-4 py-2 rounded-full text-sm font-bold hover:bg-green-700 transition">
                Daftar Sekarang
            </a>
        </div>
    </nav>

    <% if (banners && banners.length > 0) { %>
        <section class="relative w-full h-[50vh] md:h-[75vh] overflow-hidden group">
            <div id="slider-container" class="flex w-full h-full transition-transform duration-700 ease-in-out">
                <% banners.forEach(banner => { %>
                    <div class="w-full h-full flex-shrink-0 relative">
                        <img src="<%= banner.image %>" class="w-full h-full object-cover">
                        <!-- <div class="absolute inset-0 bg-black bg-opacity-40 flex items-center justify-center">
                            <h2 class="text-white text-3xl md:text-5xl font-extrabold drop-shadow-xl text-center px-4"><%= banner.title %></h2>
                        </div> -->
                    </div>
                <% }) %>
            </div>
            
            <button onclick="prevSlide()" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-black bg-opacity-50 text-white w-12 h-12 rounded-full hover:bg-green-600 transition opacity-0 group-hover:opacity-100 flex items-center justify-center text-xl z-10"><i class="fas fa-chevron-left"></i></button>
            <button onclick="nextSlide()" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-black bg-opacity-50 text-white w-12 h-12 rounded-full hover:bg-green-600 transition opacity-0 group-hover:opacity-100 flex items-center justify-center text-xl z-10"><i class="fas fa-chevron-right"></i></button>
            
            <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 flex space-x-2 z-10" id="slider-indicators">
                <% banners.forEach((_, idx) => { %>
                    <button onclick="goToSlide(<%= idx %>)" class="w-3 h-3 rounded-full bg-white bg-opacity-50 transition"></button>
                <% }) %>
            </div>
        </section>
    <% } %>

    <header class="bg-green-700 text-white text-center py-24 px-4 relative overflow-hidden">
        <div class="absolute inset-0 opacity-20" style="background-image: url('https://www.transparenttextures.com/patterns/arabesque.png');"></div>
        <div class="relative z-10">
            <h2 class="text-4xl md:text-5xl font-extrabold mb-4 drop-shadow-lg">Perjalanan Ibadah yang Penuh Berkah</h2>
            <p class="text-lg md:text-xl mb-8 max-w-2xl mx-auto opacity-90">Kami siap melayani perjalanan Umroh dan Haji Khusus Anda dengan fasilitas terbaik dan pembimbing yang berpengalaman.</p>
            <a href="#paket" class="inline-block bg-yellow-500 text-green-900 px-8 py-3 rounded-full font-bold text-lg hover:bg-yellow-400 transition shadow-lg">Lihat Paket Tersedia</a>
        </div>
    </header>

    <section id="profile" class="container mx-auto py-20 px-4">
        <div class="text-center mb-12">
            <h3 class="text-3xl font-bold text-gray-800">Profile ABBA Tour</h3>
            <div class="w-24 h-1 bg-green-600 mx-auto mt-4 rounded"></div>
            <p class="mt-6 text-gray-600 max-w-3xl mx-auto leading-relaxed">
                PT. Abu Bakar Berkah (ABBA Tour) adalah biro perjalanan wisata religi yang berfokus pada penyelenggaraan ibadah Umroh dan Haji Khusus. Kami berkomitmen untuk memberikan pelayanan sepenuh hati, membimbing jamaah sesuai sunnah, dan memastikan kenyamanan ibadah Anda di Tanah Suci.
            </p>
        </div>
    </section>

    <section id="paket" class="bg-gray-100 py-20 px-4">
        <div class="container mx-auto">
            <div class="text-center mb-16">
                <h3 class="text-3xl font-bold text-gray-800">Paket & Jadwal Tersedia</h3>
                <div class="w-24 h-1 bg-green-600 mx-auto mt-4 rounded"></div>
            </div>
            
            <div id="paket-umroh" class="mb-16">
                <h3 class="text-2xl font-bold mb-6 text-green-700 border-b-2 border-green-200 pb-2 inline-block">Program Umroh</h3>
                <% if (umrohPackages.length === 0) { %>
                    <p class="text-gray-500 italic">Belum ada jadwal keberangkatan umroh saat ini.</p>
                <% } else { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        <% umrohPackages.forEach(pkg => { %>
                            <div class="bg-white rounded-xl shadow-lg overflow-hidden flex flex-col hover:shadow-xl transition duration-300">
                                <img src="<%= pkg.image %>" class="w-full h-56 object-cover">
                                <div class="p-6 flex flex-col flex-grow">
                                    <h4 class="font-bold text-xl mb-3 text-gray-800 line-clamp-2"><%= pkg.title %></h4>
                                    <div class="flex justify-between items-center text-sm text-gray-600 mb-4 bg-gray-50 p-3 rounded-lg border border-gray-100">
                                        <span><i class="fas fa-calendar-alt text-green-600 mr-1"></i> <%= pkg.departureDate.toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}) %></span>
                                        <span><i class="fas fa-clock text-green-600 mr-1"></i> <%= pkg.duration %></span>
                                    </div>
                                    <p class="text-green-700 font-extrabold text-xl mt-auto"><%= pkg.price %></p>
                                    <a href="/paket/<%= pkg._id %>" class="mt-4 block text-center bg-green-600 text-white py-2.5 rounded-lg font-semibold hover:bg-green-700 transition">Detail Program</a>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <div id="paket-haji" class="mb-8">
                <h3 class="text-2xl font-bold mb-6 text-green-700 border-b-2 border-green-200 pb-2 inline-block">Program Haji Khusus</h3>
                <% if (hajiPackages.length === 0) { %>
                    <p class="text-gray-500 italic">Belum ada jadwal keberangkatan haji khusus saat ini.</p>
                <% } else { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        <% hajiPackages.forEach(pkg => { %>
                            <div class="bg-white rounded-xl shadow-lg overflow-hidden flex flex-col hover:shadow-xl transition duration-300">
                                <img src="<%= pkg.image %>" class="w-full h-56 object-cover">
                                <div class="p-6 flex flex-col flex-grow">
                                    <h4 class="font-bold text-xl mb-3 text-gray-800 line-clamp-2"><%= pkg.title %></h4>
                                    <div class="flex justify-between items-center text-sm text-gray-600 mb-4 bg-gray-50 p-3 rounded-lg border border-gray-100">
                                        <span><i class="fas fa-calendar-alt text-green-600 mr-1"></i> <%= pkg.departureDate.toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}) %></span>
                                        <span><i class="fas fa-clock text-green-600 mr-1"></i> <%= pkg.duration %></span>
                                    </div>
                                    <p class="text-green-700 font-extrabold text-xl mt-auto"><%= pkg.price %></p>
                                    <a href="/paket/<%= pkg._id %>" class="mt-4 block text-center bg-green-600 text-white py-2.5 rounded-lg font-semibold hover:bg-green-700 transition">Detail Program</a>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div> 
        </div>
    </section>

    <section id="galeri" class="container mx-auto py-20 px-4">
        <div class="text-center mb-12">
            <h3 class="text-3xl font-bold text-gray-800">Galeri Keberangkatan</h3>
            <div class="w-24 h-1 bg-green-600 mx-auto mt-4 rounded"></div>
            <p class="mt-4 text-gray-600">Momen berharga jamaah ABBA Tour di Tanah Suci.</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <% if (galleries.length === 0) { %>
                <div class="col-span-full text-center text-gray-500 py-10">Belum ada foto di galeri.</div>
            <% } else { %>
                <% galleries.forEach((foto, index) => { %>
                    <div class="relative group overflow-hidden rounded-lg shadow cursor-pointer" onclick="openLightbox(<%= index %>)">
                        <img src="<%= foto.image %>" class="w-full h-48 object-cover transform group-hover:scale-110 transition duration-500">
                        <div class="absolute inset-0 bg-green-900 bg-opacity-40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300">
                            <i class="fas fa-search-plus text-white text-4xl drop-shadow-md"></i>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </section>

    <section id="artikel" class="bg-gray-100 py-20 px-4">
        <div class="container mx-auto">
            <div class="text-center mb-12">
                <h3 class="text-3xl font-bold text-gray-800">Artikel & Panduan</h3>
                <div class="w-24 h-1 bg-green-600 mx-auto mt-4 rounded"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <% if (articles.length === 0) { %>
                    <div class="col-span-full text-center text-gray-500 py-10">Belum ada artikel.</div>
                <% } else { %>
                    <% articles.forEach(artikel => { %>
                        <div class="bg-white rounded-lg shadow overflow-hidden flex flex-col hover:shadow-lg transition">
                            <img src="<%= artikel.image %>" class="w-full h-48 object-cover">
                            <div class="p-6 flex flex-col flex-grow">
                                <h4 class="font-bold text-lg mb-2 text-gray-800"><%= artikel.title %></h4>
                                <p class="text-xs text-gray-400 mb-4"><i class="fas fa-calendar-day mr-1"></i> <%= artikel.createdAt.toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'}) %></p>
                                <p class="text-sm text-gray-600 line-clamp-3 mb-4"><%= artikel.content %></p>
                                <a href="/artikel/<%= artikel._id %>" class="mt-auto inline-block text-green-600 font-bold text-sm text-left hover:text-green-800 transition">
                                    Baca Selengkapnya &rarr;
                                </a>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </section>

    <section id="kontak" class="bg-white py-20 border-t border-gray-200">
        <div class="container mx-auto px-4">
            <div class="text-center mb-12">
                <h3 class="text-3xl font-bold text-gray-800">Hubungi Kami</h3>
                <div class="w-24 h-1 bg-green-600 mx-auto mt-4 rounded"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
                <div class="bg-gray-50 p-8 rounded-xl text-center shadow-sm border border-gray-100">
                    <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl"><i class="fas fa-map-marker-alt"></i></div>
                    <h4 class="text-lg font-bold text-gray-800 mb-2">Kantor Pusat</h4>
                    <p class="text-gray-600">Jl. Contoh Alamat No. 123<br>Semarang, Jawa Tengah</p>
                </div>
                <div class="bg-gray-50 p-8 rounded-xl text-center shadow-sm border border-gray-100">
                    <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl"><i class="fab fa-whatsapp"></i></div>
                    <h4 class="text-lg font-bold text-gray-800 mb-2">Telepon / WhatsApp</h4>
                    <a href="https://wa.me/6281234567890" target="_blank" class="text-green-600 font-bold hover:underline">+62 812-3456-7890</a>
                </div>
                <div class="bg-gray-50 p-8 rounded-xl text-center shadow-sm border border-gray-100">
                    <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl"><i class="fas fa-envelope"></i></div>
                    <h4 class="text-lg font-bold text-gray-800 mb-2">Email</h4>
                    <a href="mailto:info@abbatour.co.id" class="text-green-600 font-bold hover:underline">info@abbatour.co.id</a>
                </div>
            </div>
        </div>
    </section>
