    <footer class="bg-gray-900 text-gray-400 py-8 text-center border-t-4 border-green-700">
        <p>&copy; 2026 PT. Abu Bakar Berkah (ABBA Tour). Melayani dengan Hati.</p>
    </footer>

    <div id="lightbox" class="fixed inset-0 z-[100] hidden bg-black bg-opacity-95 flex items-center justify-center select-none backdrop-blur-sm">
        
        <button onclick="closeLightbox()" class="absolute top-6 right-6 md:top-10 md:right-10 text-gray-400 hover:text-white transition text-4xl lg:text-5xl z-50">&times;</button>
        
        <button onclick="changeLightboxImage(-1)" class="absolute left-2 md:left-8 text-gray-400 hover:text-white transition text-4xl md:text-6xl p-4 z-50">
            <i class="fas fa-chevron-left"></i>
        </button>
        
        <div class="relative w-full max-w-5xl max-h-screen px-16 flex flex-col items-center justify-center">
            <img id="lightbox-img" src="" class="max-w-full max-h-[80vh] object-contain rounded shadow-2xl transition-all duration-300">
            <p id="lightbox-caption" class="text-white text-center mt-6 text-lg md:text-xl font-medium tracking-wide"></p>
        </div>
        
        <button onclick="changeLightboxImage(1)" class="absolute right-2 md:right-8 text-gray-400 hover:text-white transition text-4xl md:text-6xl p-4 z-50">
            <i class="fas fa-chevron-right"></i>
        </button>
    </div>

    <script>
        // Logika Slider / Carousel Atas
        <% if (banners && banners.length > 0) { %>
            let currentSlide = 0;
            const totalSlides = <%= banners.length %>;
            const sliderContainer = document.getElementById('slider-container');
            const indicators = document.querySelectorAll('.slide-indicator');

            function updateSlider() {
                sliderContainer.style.transform = `translateX(-${currentSlide * 100}%)`;
                const indicators = document.getElementById('slider-indicators').children;
                for(let i=0; i<indicators.length; i++) {
                    indicators[i].className = i === currentSlide ? "w-3 h-3 rounded-full bg-white transition" : "w-3 h-3 rounded-full bg-white bg-opacity-50 transition";
                }
            }
            function nextSlide() { currentSlide = (currentSlide + 1) % totalSlides; updateSlider(); }
            function prevSlide() { currentSlide = (currentSlide - 1 + totalSlides) % totalSlides; updateSlider(); }
            function goToSlide(index) { currentSlide = index; updateSlider(); }
            
            // Inisialisasi indikator awal & otomatis geser tiap 5 detik
            updateSlider();
            setInterval(nextSlide, 5000); 
        <% } %>
        // Mengambil data galeri dari database via EJS lalu diubah ke JSON
        const galleryData = <%- JSON.stringify(galleries) %>;
        let currentIndex = 0;

        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        const lightboxCaption = document.getElementById('lightbox-caption');

        // Fungsi Buka Gambar
        function openLightbox(index) {
            currentIndex = index;
            updateLightboxContent();
            lightbox.classList.remove('hidden');
            document.body.style.overflow = 'hidden'; // Kunci scroll halaman web di belakangnya
        }

        // Fungsi Tutup Gambar
        function closeLightbox() {
            lightbox.classList.add('hidden');
            document.body.style.overflow = 'auto'; // Kembalikan scroll halaman
        }

        // Fungsi Ganti Gambar Kanan / Kiri
        function changeLightboxImage(direction) {
            currentIndex += direction;
            
            // Logika Looping: jika sudah gambar terakhir, kembali ke gambar pertama
            if (currentIndex >= galleryData.length) {
                currentIndex = 0;
            } else if (currentIndex < 0) {
                currentIndex = galleryData.length - 1;
            }
            
            updateLightboxContent();
        }

        // Fungsi Pasang Gambar ke Layar
        function updateLightboxContent() {
            if (galleryData.length > 0) {
                lightboxImg.src = galleryData[currentIndex].image;
                lightboxCaption.textContent = galleryData[currentIndex].title;
            }
        }

        // Opsional: Tutup lightbox jika user mengklik area gelap di luar gambar
        lightbox.addEventListener('click', function(e) {
            if (e.target === lightbox) {
                closeLightbox();
            }
        });
    </script>

</body>
</html>