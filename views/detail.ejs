<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Paket - ABBA Tour</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50 font-sans">

    <nav class="bg-white shadow-md p-4 sticky top-0 z-50">
        <div class="container mx-auto">
            <a href="/" class="text-xl font-bold text-green-700 hover:text-green-800 transition">← Kembali ke Beranda</a>
        </div>
    </nav>

    <main class="container mx-auto py-12 px-4">
        <div class="bg-white rounded-xl shadow-lg overflow-hidden max-w-5xl mx-auto flex flex-col md:flex-row">
            
            <div class="md:w-1/2">
                <img src="<%= pkg.image %>" alt="<%= pkg.title %>" class="w-full h-full object-cover">
            </div>

            <div class="md:w-1/2 p-8 flex flex-col justify-center">
                <div class="inline-block bg-yellow-100 text-yellow-800 text-sm font-semibold px-3 py-1 rounded-full mb-4 w-max">
                    Program <%= pkg.type %>
                </div>
                <h1 class="text-3xl font-extrabold text-gray-800 mb-4"><%= pkg.title %></h1>
                
                <div class="bg-gray-50 p-4 rounded-lg mb-6 border border-gray-200">
                    <div class="flex items-center text-gray-700 mb-2">
                        <i class="fas fa-calendar-alt text-green-600 w-6"></i> 
                        <span class="font-semibold mr-2">Keberangkatan:</span> 
                        <%= pkg.departureDate ? pkg.departureDate.toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) : 'Menunggu Jadwal' %>
                    </div>
                    <div class="flex items-center text-gray-700">
                        <i class="fas fa-clock text-green-600 w-6"></i>
                        <span class="font-semibold mr-2">Durasi Program:</span> 
                        <%= pkg.duration %>
                    </div>
                </div>

                <div class="text-2xl font-bold text-green-600 mb-6"><%= pkg.price %></div>
                
                <h3 class="text-lg font-semibold text-gray-700 mb-2">Fasilitas & Keterangan:</h3>
                <p class="text-gray-600 mb-8 whitespace-pre-wrap leading-relaxed"><%= pkg.description %></p>
                
                <% 
                   const pesanWa = `Assalamu'alaikum admin ABBA Tour, saya tertarik dengan *${pkg.title}* (${pkg.duration}) seharga ${pkg.price}. Bisa minta informasi lebih lanjut?`;
                   const linkWa = `https://wa.me/6281234567890?text=${encodeURIComponent(pesanWa)}`;
                %>
                <a href="<%= linkWa %>" target="_blank" class="bg-green-600 text-white text-center px-6 py-4 rounded-lg font-bold text-lg hover:bg-green-700 transition flex items-center justify-center gap-2 shadow-md">
                    <i class="fab fa-whatsapp text-2xl"></i> Konsultasi & Pesan via WhatsApp
                </a>
            </div>

        </div>
    </main>

    <footer class="bg-gray-800 text-gray-300 py-6 text-center mt-12">
        <p>&copy; 2026 PT. Abu Bakar Berkah (ABBA Tour).</p>
    </footer>

</body>
</html>