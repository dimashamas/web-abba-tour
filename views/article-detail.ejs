<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= article.title %> - ABBA Tour</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50 font-sans text-gray-800">

    <nav class="bg-white shadow-md p-4 sticky top-0 z-50">
        <div class="container mx-auto">
            <a href="/#artikel" class="text-xl font-bold text-green-700 hover:text-green-800 transition">← Kembali ke Artikel</a>
        </div>
    </nav>

    <main class="container mx-auto py-12 px-4 max-w-4xl">
        <article class="bg-white rounded-xl shadow-md overflow-hidden p-6 md:p-10">
            
            <header class="mb-6">
                <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 leading-tight mb-4">
                    <%= article.title %>
                </h1>
                <div class="flex items-center text-sm text-gray-500 space-x-4">
                    <span><i class="fas fa-calendar-day text-green-600 mr-1"></i> <%= article.createdAt.toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
                    <span><i class="fas fa-user text-green-600 mr-1"></i> Admin ABBA Tour</span>
                </div>
            </header>

            <div class="mb-8 rounded-xl overflow-hidden shadow-sm">
                <img src="<%= article.image %>" alt="<%= article.title %>" class="w-full h-auto md:max-h-[450px] object-cover mx-auto">
            </div>

            <div class="prose max-w-none text-gray-700 text-lg leading-relaxed whitespace-pre-wrap">
                <%= article.content %>
            </div>

            <div class="mt-12 pt-8 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-4">
                <div>
                    <h4 class="font-bold text-gray-800">Tertarik Beribadah Bersama Kami?</h4>
                    <p class="text-sm text-gray-500">Dapatkan konsultasi program Umroh & Haji Khusus terbaik.</p>
                </div>
                <a href="https://wa.me/6281234567890" target="_blank" class="bg-green-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-green-700 transition flex items-center gap-2 shadow-sm">
                    <i class="fab fa-whatsapp text-xl"></i> Hubungi Admin Sekarang
                </a>
            </div>

        </article>
    </main>

    <footer class="bg-gray-900 text-gray-400 py-6 text-center mt-12">
        <p>&copy; 2026 PT. Abu Bakar Berkah (ABBA Tour).</p>
    </footer>

</body>
</html>