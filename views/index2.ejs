    <style>
        /* ── RESET / BASE ── */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html {
            scroll-behavior: smooth;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: #fafcfb;
            overflow-x: hidden;
        }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #e5e7eb;
        }
        ::-webkit-scrollbar-thumb {
            background: #15803d;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #166534;
        }

        /* ── GLASSMORPHISM ── */
        .glass {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.25);
        }
        .glass-dark {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        /* ── NAVBAR ── */
        .navbar {
            transition: all 0.3s ease;
        }
        .navbar-scrolled {
            background: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
            border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        }

        /* ── HERO ── */
        .hero-gradient {
            background: linear-gradient(135deg, #0a2e1a 0%, #1a4a2a 40%, #2d6a3f 100%);
        }
        .hero-pattern {
            background-image: radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.02) 0%, transparent 40%);
        }
        .floating-shapes span {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
            animation: floatShape 20s infinite ease-in-out alternate;
        }
        @keyframes floatShape {
            0% {
                transform: translate(0, 0) scale(1) rotate(0deg);
            }
            100% {
                transform: translate(40px, -60px) scale(1.2) rotate(20deg);
            }
        }

        .hero-title span {
            display: inline-block;
            animation: fadeUp 1s ease forwards;
            opacity: 0;
        }
        .hero-title span:nth-child(1) {
            animation-delay: 0.1s;
        }
        .hero-title span:nth-child(2) {
            animation-delay: 0.2s;
        }
        .hero-title span:nth-child(3) {
            animation-delay: 0.3s;
        }
        .hero-title span:nth-child(4) {
            animation-delay: 0.4s;
        }
        .hero-title span:nth-child(5) {
            animation-delay: 0.5s;
        }
        .hero-title span:nth-child(6) {
            animation-delay: 0.6s;
        }
        .hero-title span:nth-child(7) {
            animation-delay: 0.7s;
        }
        .hero-title span:nth-child(8) {
            animation-delay: 0.8s;
        }
        .hero-title span:nth-child(9) {
            animation-delay: 0.9s;
        }

        @keyframes fadeUp {
            0% {
                opacity: 0;
                transform: translateY(30px);
            }
            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── SLIDER ── */
        .slider-btn {
            transition: all 0.3s ease;
        }
        .slider-btn:hover {
            background: #15803d;
            transform: scale(1.08);
        }
        .slider-dot {
            transition: all 0.3s ease;
        }
        .slider-dot.active {
            background: #15803d;
            width: 28px;
            border-radius: 10px;
        }

        /* ── PACKAGE CARDS ── */
        .package-card {
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            transform: translateY(0);
        }
        .package-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 30px 60px -20px rgba(21, 128, 61, 0.25);
        }
        .package-card .card-image {
            transition: all 0.6s ease;
        }
        .package-card:hover .card-image {
            transform: scale(1.05);
        }
        .package-badge {
            position: absolute;
            top: 16px;
            right: 16px;
            background: rgba(21, 128, 61, 0.92);
            backdrop-filter: blur(8px);
            padding: 4px 14px;
            border-radius: 30px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        /* ── GALLERY ── */
        .gallery-item {
            overflow: hidden;
            border-radius: 16px;
            position: relative;
            cursor: pointer;
        }
        .gallery-item img {
            transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .gallery-item:hover img {
            transform: scale(1.08);
        }
        .gallery-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(10, 46, 26, 0.7), rgba(21, 128, 61, 0.4));
            opacity: 0;
            transition: all 0.4s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 16px;
        }
        .gallery-item:hover .gallery-overlay {
            opacity: 1;
        }

        /* ── LIGHTBOX ── */
        .lightbox {
            background: rgba(0, 0, 0, 0.92);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        /* ── ANIMATED COUNTER ── */
        .stat-number {
            font-size: 2.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, #15803d, #22c55e);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ── ARTICLES ── */
        .article-card {
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .article-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.12);
        }

        /* ── WHATSAPP FLOAT ── */
        .wa-float {
            animation: waPulse 2.5s infinite ease-in-out;
            box-shadow: 0 8px 32px rgba(37, 211, 102, 0.35);
        }
        @keyframes waPulse {
            0%,
            100% {
                transform: scale(1);
                box-shadow: 0 8px 32px rgba(37, 211, 102, 0.35);
            }
            50% {
                transform: scale(1.06);
                box-shadow: 0 12px 48px rgba(37, 211, 102, 0.55);
            }
        }
        .wa-ring {
            animation: waRing 2.5s infinite ease-in-out;
        }
        @keyframes waRing {
            0%,
            100% {
                transform: scale(1);
                opacity: 0.6;
            }
            50% {
                transform: scale(1.25);
                opacity: 0;
            }
        }

        /* ── SECTION TITLE ── */
        .section-title {
            font-weight: 800;
            letter-spacing: -0.02em;
        }
        .section-underline {
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, #15803d, #22c55e);
            border-radius: 10px;
            margin: 16px auto 0;
        }

        /* ── SCROLL REVEAL ── */
        .reveal {
            opacity: 0;
            transform: translateY(50px);
            transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 768px) {
            .hero-title {
                font-size: 2.4rem !important;
            }
            .stat-number {
                font-size: 2rem;
            }
            .floating-shapes span {
                display: none;
            }
        }

        /* ── MOBILE MENU ── */
        .mobile-menu {
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            transform: translateX(100%);
            opacity: 0;
        }
        .mobile-menu.open {
            transform: translateX(0);
            opacity: 1;
        }
        .menu-overlay {
            transition: all 0.4s ease;
            opacity: 0;
            pointer-events: none;
        }
        .menu-overlay.open {
            opacity: 1;
            pointer-events: auto;
        }

        /* ── FOOTER ── */
        .footer-gradient {
            background: linear-gradient(135deg, #0a2e1a 0%, #0f3d22 100%);
        }
    </style>
</head>
