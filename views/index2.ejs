                <div class="flex items-center gap-3 mb-7">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg" style="background:rgba(14,124,111,0.1); color:var(--emerald-2);">
                        <i class="fas fa-mosque"></i>
                    </div>
                    <h3 class="font-display text-2xl font-medium" style="color:var(--ink);">Program <span style="color:var(--emerald-2); font-style:italic;">Umroh</span></h3>
                </div>

                <% if (umrohPackages.length === 0) { %>
                <p class="italic rounded-xl p-8 text-center shadow-sm border" style="color:var(--stone); background:var(--paper); border-color:var(--line);">Belum ada jadwal keberangkatan umroh saat ini.</p>
                <% } else { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-10">
                    <% umrohPackages.forEach((pkg, idx) => { %>
                    <div class="ticket-card reveal" style="transition-delay:<%= (idx * 0.08) %>s;">
                        <div class="ticket-media">
                            <img src="<%= pkg.image %>" />
                            <span class="ticket-tag">Umroh</span>
                        </div>
                        <div class="ticket-perf"><div class="ticket-perf-line"></div></div>
                        <div class="package-card-body">
                            <h4 class="font-bold text-xl mb-3 line-clamp-2" style="color:var(--ink);"><%= pkg.title %></h4>
                            <div class="flex flex-wrap items-center gap-2 text-xs mb-5" style="color:var(--stone);">
                                <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full" style="background:var(--sand);">
                                    <i class="fas fa-calendar-alt" style="color:var(--emerald-2);"></i> <%= pkg.departureDate.toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'}) %>
                                </span>
                                <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full" style="background:var(--sand);">
                                    <i class="fas fa-clock" style="color:var(--emerald-2);"></i> <%= pkg.duration %>
                                </span>
                            </div>
                            <div class="flex items-center justify-between mt-2 pt-4" style="border-top:1px dashed var(--line);">
                                <span class="stub-price text-2xl" style="color:var(--emerald-2);"><%= pkg.price %></span>
                                <a href="/paket/<%= pkg._id %>" class="btn-detail inline-flex items-center gap-2 text-white px-5 py-2.5 rounded-full text-sm font-bold" style="background:var(--emerald);">
                                    Detail <i class="fas fa-arrow-right text-xs"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
                <% } %>
