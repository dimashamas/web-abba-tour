                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg" style="background:rgba(169,117,76,0.15); color:var(--gold);">
                        <i class="fas fa-kaaba"></i>
                    </div>
                    <h3 class="font-display text-2xl font-medium" style="color:var(--ink);">Program <span style="color:var(--gold); font-style:italic;">Haji Khusus</span></h3>
