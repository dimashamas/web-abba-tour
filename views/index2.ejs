<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="msapplication-TileImage" content="/assets/logo-270.png"/>
    <link rel="icon" type="image/png" href="/assets/logo-270.png">
    <link rel="apple-touch-icon" sizes="180x180" href="i/assets/logo-180.png">
    <link rel="icon" sizes="192x192" href="/assets/logo-192.png">
    <title>ABBA Tour — PT. Abu Bakar Berkah</title>
    <meta name="description" content="Penyelenggara Resmi ibadah Umroh dan Haji Khusus dengan pembimbing profesional dan fasilitas terbaik.">

    <!-- Open Graph Meta Tags -->
    <meta property="og:url" content="https://abbatour.dimashamas.my.id/">
    <meta property="og:type" content="website">
    <meta property="og:title" content="ABBA Tour — PT. Abu Bakar Berkah">
    <meta property="og:description" content="Penyelenggara Resmi ibadah Umroh dan Haji Khusus dengan pembimbing profesional dan fasilitas terbaik.">
    <meta property="og:image" content="https://abbatour.dimashamas.my.id/assets/thumbnail-1000x1000.jpg">
    <meta property="og:image:width" content="1000">
    <meta property="og:image:height" content="1000">

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta property="twitter:domain" content="abbatour.dimashamas.my.id">
    <meta property="twitter:url" content="https://abbatour.dimashamas.my.id/">
    <meta name="twitter:title" content="ABBA Tour — PT. Abu Bakar Berkah">
    <meta name="twitter:description" content="Penyelenggara Resmi ibadah Umroh dan Haji Khusus dengan pembimbing profesional dan fasilitas terbaik.">
    <meta name="twitter:image" content="https://abbatour.dimashamas.my.id/assets/thumbnail-1000x1000.jpg">

    <!-- Tailwind + Fonts + Icons -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        /* ═══════════════════ TOKENS ═══════════════════ */
        :root{
            --ink:        #16302B;   /* deep toska-charcoal ink, headings */
            --ink-soft:   #4B5A53;   /* body text on light */
            --stone:      #8C8574;   /* muted / captions */
            --sand:       #F7EFDD;   /* creamy paper background */
            --sand-deep:  #EBDCC0;   /* deeper cream / khaki */
            --paper:      #FFFDF6;   /* card cream-white */
            --emerald:    #0A3733;   /* deep toska ink — hero / footer */
            --emerald-2:  #0E7C6F;   /* hijau toska — CTAs */
            --emerald-3:  #2FA89A;   /* lighter toska accent */
            --gold:       #A9754C;   /* coklat krem — warm accent */
            --gold-soft:  #D9B589;   /* soft caramel-cream */
            --line:       rgba(22,48,43,0.10);
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body {
            font-family:'Plus Jakarta Sans', sans-serif;
            background: var(--sand);
            color: var(--ink-soft);
            overflow-x:hidden;
        }
        .font-display{ font-family:'Fraunces', serif; }
        .eyebrow{
            font-family:'Plus Jakarta Sans', sans-serif;
            font-weight:700;
            font-size:0.72rem;
            letter-spacing:0.22em;
            text-transform:uppercase;
        }

        ::-webkit-scrollbar{ width:9px; }
        ::-webkit-scrollbar-track{ background:var(--sand-deep); }
        ::-webkit-scrollbar-thumb{ background:var(--emerald-2); border-radius:10px; }
        ::-webkit-scrollbar-thumb:hover{ background:var(--emerald); }

        /* ═══════════════════ SIGNATURE: GEOMETRIC LATTICE ═══════════════════ */
        .lattice-bg{ position:absolute; inset:0; pointer-events:none; }

        /* ═══════════════════ NAVBAR ═══════════════════ */
        .navbar{ transition: all .35s ease; }
        .navbar-scrolled{
            background: rgba(247,242,230,0.88) !important;
            backdrop-filter: blur(18px) saturate(160%);
            -webkit-backdrop-filter: blur(18px) saturate(160%);
            box-shadow: 0 1px 0 var(--line);
        }
        .nav-link{ position:relative; }
        .nav-link::after{
            content:''; position:absolute; left:0; right:0; bottom:-6px; height:2px;
            background: var(--gold); transform:scaleX(0); transform-origin:left;
            transition: transform .3s ease;
        }
        .nav-link:hover::after{ transform:scaleX(1); }

        /* ═══════════════════ HERO ═══════════════════ */
        .hero-emerald{
            background:
                radial-gradient(120% 90% at 85% 0%, rgba(47,168,154,0.32) 0%, transparent 55%),
                radial-gradient(90% 70% at 10% 100%, rgba(169,117,76,0.14) 0%, transparent 55%),
                linear-gradient(160deg, #082521 0%, var(--emerald) 55%, #0A3733 100%);
        }
        .hero-title .accent{ color: var(--gold-soft); font-style:italic; }
        .hero-title span{
            display:inline-block; opacity:0; transform:translateY(24px);
            animation: riseIn .9s cubic-bezier(.22,1,.36,1) forwards;
        }
        @keyframes riseIn{ to{ opacity:1; transform:translateY(0); } }

        .divider-gold{
            width:46px; height:2px; background:var(--gold);
            position:relative;
        }
        .divider-gold::before{
            content:''; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%) rotate(45deg);
            width:6px; height:6px; background:var(--gold);
        }

        /* ticket-perforation divider used between hero and stat-strip */
        .perforation{
            position:relative; height:0;
        }
        .perforation svg{ display:block; width:100%; height:22px; }

        /* ═══════════════════ SLIDER ═══════════════════ */
        .slider-btn{ transition: all .3s ease; }
        .slider-btn:hover{ background: var(--gold); color:var(--ink); border-color:var(--gold); transform:scale(1.06); }
        .slider-dot{ transition: all .3s ease; }
        .slider-dot.active{ background: var(--gold); width:26px; border-radius:10px; }

        /* ═══════════════════ STAT STRIP ═══════════════════ */
        .stat-strip{ background: var(--emerald); }
        .stat-num{
            font-family:'Fraunces', serif; font-weight:600; font-size:2.4rem; color:var(--gold-soft);
        }
        .stat-div{ border-left:1px solid rgba(255,255,255,0.12); }

        /* ═══════════════════ SECTION HEADERS ═══════════════════ */
        .section-title{ font-weight:600; letter-spacing:-0.01em; }

        /* ═══════════════════ TICKET / BOARDING-PASS PACKAGE CARDS ═══════════════════ */
        .ticket-card{
            background: var(--paper);
            border: 1px solid var(--line);
            border-radius: 18px;
            overflow: visible;
            position: relative;
            transition: transform .45s cubic-bezier(.22,1,.36,1), box-shadow .45s ease;
        }
        .ticket-card:hover{
            transform: translateY(-8px);
            box-shadow: 0 28px 55px -25px rgba(14,42,30,0.35);
        }
        .ticket-media{
            position:relative; height:14rem; overflow:hidden;
            border-radius:18px 18px 0 0;
        }
        .ticket-media img{ width:100%; height:100%; object-fit:cover; transition: transform .7s ease; }
        .ticket-card:hover .ticket-media img{ transform:scale(1.06); }
        .ticket-tag{
            position:absolute; top:14px; left:14px;
            background: rgba(14,42,30,0.85); backdrop-filter: blur(6px);
            color:#F7EFDD; font-size:0.66rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase;
            padding:6px 12px; border-radius:999px; border:1px solid rgba(255,255,255,0.18);
        }
        .ticket-tag.haji{ background: rgba(169,117,76,0.92); color:#2B1B10; }

        /* perforation notch row between media and body — the "tear here" of a boarding pass */
        .ticket-perf{
            position:relative; height:0; background:transparent;
        }
        .ticket-perf::before, .ticket-perf::after{
            content:''; position:absolute; top:-11px; width:22px; height:22px; border-radius:50%;
            background: var(--sand-deep); z-index:2;
        }
        .ticket-perf::before{ left:-11px; }
        .ticket-perf::after{ right:-11px; }
        .ticket-perf-line{
            border-top: 2px dashed rgba(20,34,25,0.18);
            margin: 0 22px;
        }
        .package-card-body{ padding: 22px 22px 24px; }

        .stub-price{
            font-family:'Fraunces', serif; font-weight:600; letter-spacing:-0.01em;
        }
        .btn-detail{
            transition: all .3s ease;
        }
        .btn-detail:hover{ gap:12px; }

        /* ═══════════════════ GALLERY ═══════════════════ */
        .album-card{
            opacity:0; transform:translateY(26px);
            animation: fadeUpAlbum .8s cubic-bezier(.22,1,.36,1) forwards;
        }
        @keyframes fadeUpAlbum{ to{ opacity:1; transform:translateY(0); } }
        .album-media{ position:relative; height:14rem; overflow:hidden; border-radius:16px 16px 0 0; background:var(--sand-deep); }
        .album-media img{ width:100%; height:100%; object-fit:cover; transition: transform .7s cubic-bezier(.22,1,.36,1); }
        .album-card:hover .album-media img{ transform:scale(1.09); }
        .album-overlay{
            position:absolute; inset:0;
            background: linear-gradient(0deg, rgba(10,32,22,0.75) 0%, rgba(10,32,22,0.05) 55%, transparent 100%);
            opacity:0; transition: opacity .45s ease;
        }
        .album-card:hover .album-overlay{ opacity:1; }

        /* ═══════════════════ ARTICLES ═══════════════════ */
        .article-card{ transition: transform .4s cubic-bezier(.22,1,.36,1), box-shadow .4s ease; }
        .article-card:hover{ transform: translateY(-6px); box-shadow: 0 24px 46px -22px rgba(20,34,25,0.22); }

        /* ═══════════════════ WHATSAPP FLOAT ═══════════════════ */
        .wa-float{ animation: waPulse 2.6s infinite ease-in-out; box-shadow: 0 10px 34px rgba(14,124,111,0.4); }
        @keyframes waPulse{
            0%,100%{ transform:scale(1); box-shadow:0 10px 34px rgba(14,124,111,0.4); }
            50%{ transform:scale(1.05); box-shadow:0 14px 46px rgba(14,124,111,0.55); }
        }
        .wa-ring{ animation: waRing 2.6s infinite ease-in-out; }
        @keyframes waRing{ 0%,100%{ transform:scale(1); opacity:.55; } 50%{ transform:scale(1.3); opacity:0; } }

        /* ═══════════════════ LIGHTBOX ═══════════════════ */
        .lightbox{ background: rgba(10,20,14,0.94); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); }

        /* ═══════════════════ SCROLL REVEAL ═══════════════════ */
        .reveal{ opacity:0; transform:translateY(46px); transition: all .8s cubic-bezier(.22,1,.36,1); }
        .reveal.visible{ opacity:1; transform:translateY(0); }

        /* ═══════════════════ MOBILE MENU ═══════════════════ */
        .mobile-menu{ transition: all .4s cubic-bezier(.22,1,.36,1); transform:translateX(100%); opacity:0; }
        .mobile-menu.open{ transform:translateX(0); opacity:1; }
        .menu-overlay{ transition: all .4s ease; opacity:0; pointer-events:none; }
        .menu-overlay.open{ opacity:1; pointer-events:auto; }

        .line-clamp-2{ display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
        .line-clamp-3{ display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }

        @media (max-width: 768px){
            .hero-title{ font-size:2.5rem !important; }
            .stat-num{ font-size:1.9rem; }
        }
    </style>
</head>
<body>

    <!-- ════════════════════════════════════════════ -->
    <!--  NAVBAR                                      -->
    <!-- ════════════════════════════════════════════ -->
    <nav id="navbar" class="navbar fixed top-0 left-0 w-full z-50 py-3 px-4 md:px-8">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <a href="/" class="flex items-center">
                <img src="/assets/logo.png" alt="Logo ABBA Tour" class="h-11 w-auto object-contain">
            </a>

            <ul class="hidden lg:flex items-center gap-9 text-sm font-semibold" style="color:var(--ink);">
                <li><a href="#" class="nav-link hover:text-[var(--emerald-2)] transition-colors">Beranda</a></li>
                <li><a href="#profile" class="nav-link hover:text-[var(--emerald-2)] transition-colors">Profile</a></li>
                <li class="relative group">
                    <a href="#paket" class="nav-link hover:text-[var(--emerald-2)] transition-colors flex items-center gap-1.5 cursor-pointer">
                        Paket <i class="fas fa-chevron-down text-[9px]"></i>
                    </a>
                    <div class="absolute left-0 mt-3 w-56 bg-[var(--paper)] rounded-2xl shadow-2xl border border-[var(--line)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 py-2">
                        <a href="#paket-umroh" class="block px-5 py-3 text-sm font-medium hover:bg-[var(--sand)] transition">🕋 Paket Umroh</a>
                        <a href="#paket-haji" class="block px-5 py-3 text-sm font-medium hover:bg-[var(--sand)] transition">🕊️ Paket Haji Khusus</a>
                    </div>
                </li>
                <li><a href="#galeri" class="nav-link hover:text-[var(--emerald-2)] transition-colors">Galeri</a></li>
                <li><a href="#artikel" class="nav-link hover:text-[var(--emerald-2)] transition-colors">Artikel</a></li>
                <li><a href="#kontak" class="nav-link hover:text-[var(--emerald-2)] transition-colors">Hubungi</a></li>
            </ul>

            <a href="#kontak" class="hidden lg:inline-flex items-center gap-2 bg-[var(--emerald)] text-[var(--sand)] px-6 py-2.5 rounded-full text-sm font-bold hover:bg-[var(--emerald-2)] transition-all duration-300 border border-transparent hover:border-[var(--gold)]">
                Daftar Sekarang <i class="fas fa-arrow-right text-xs"></i>
            </a>

            <button id="hamburger" class="lg:hidden w-10 h-10 rounded-xl flex flex-col items-center justify-center gap-1.5 bg-[var(--paper)] border border-[var(--line)]" aria-label="Menu">
                <span class="block w-5 h-0.5 rounded-full" style="background:var(--ink);"></span>
                <span class="block w-5 h-0.5 rounded-full" style="background:var(--ink);"></span>
                <span class="block w-5 h-0.5 rounded-full" style="background:var(--ink);"></span>
            </button>
        </div>
    </nav>

    <div id="menuOverlay" class="menu-overlay fixed inset-0 z-40 bg-black/45 backdrop-blur-sm"></div>

    <div id="mobileMenu" class="mobile-menu fixed top-0 right-0 h-full w-72 z-50 bg-[var(--paper)] shadow-2xl border-l border-[var(--line)] p-6 flex flex-col">
        <div class="flex justify-between items-center mb-8">
            <span class="font-display text-xl font-semibold" style="color:var(--ink);">ABBA <span style="color:var(--emerald-2);">Tour</span></span>
            <button id="closeMenu" class="w-9 h-9 rounded-full bg-[var(--sand)] flex items-center justify-center text-[var(--ink-soft)]">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <ul class="flex flex-col gap-4 font-medium text-base" style="color:var(--ink-soft);">
            <li><a href="#" class="block py-2 hover:text-[var(--emerald-2)] transition">Beranda</a></li>
            <li><a href="#profile" class="block py-2 hover:text-[var(--emerald-2)] transition">Profile</a></li>
            <li><a href="#paket-umroh" class="block py-2 hover:text-[var(--emerald-2)] transition">Paket Umroh</a></li>
            <li><a href="#paket-haji" class="block py-2 hover:text-[var(--emerald-2)] transition">Paket Haji Khusus</a></li>
            <li><a href="#galeri" class="block py-2 hover:text-[var(--emerald-2)] transition">Galeri</a></li>
            <li><a href="#artikel" class="block py-2 hover:text-[var(--emerald-2)] transition">Artikel</a></li>
            <li><a href="#kontak" class="block py-2 hover:text-[var(--emerald-2)] transition">Hubungi Kami</a></li>
        </ul>
        <div class="mt-auto pt-6 border-t border-[var(--line)]">
            <a href="#kontak" class="block w-full bg-[var(--emerald)] text-[var(--sand)] text-center py-3 rounded-full font-bold">
                Daftar Sekarang
            </a>
            <div class="flex items-center justify-center gap-4 mt-4" style="color:var(--stone);">
                <a href="https://www.facebook.com/share/198GvfRZpW/" class="hover:text-[var(--emerald-2)] transition"><i class="fab fa-facebook-f"></i></a>
                <a href="https://www.instagram.com/abbatourandtravel/" class="hover:text-[var(--emerald-2)] transition"><i class="fab fa-instagram"></i></a>
                <a href="https://youtube.com/@abubakarberkah?si=sefiV89FUTDYU-kV" class="hover:text-[var(--emerald-2)] transition"><i class="fab fa-youtube"></i></a>
            </div>
        </div>
    </div>


    <!-- ════════════════════════════════════════════ -->
    <!--  HERO / SLIDER                              -->
    <!-- ════════════════════════════════════════════ -->
    <% if (banners && banners.length > 0) { %>
    <section class="relative w-full h-[78vh] md:h-[92vh] overflow-hidden hero-emerald mt-0">

        <!-- signature: interlocking geometric lattice -->
        <svg class="lattice-bg" width="100%" height="100%" preserveAspectRatio="none">
            <defs>
                <pattern id="starPattern" width="86" height="86" patternUnits="userSpaceOnUse">
                    <g stroke="#A9754C" stroke-width="1" fill="none" opacity="0.35">
                        <rect x="21" y="21" width="44" height="44"></rect>
                        <rect x="21" y="21" width="44" height="44" transform="rotate(45 43 43)"></rect>
                    </g>
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#starPattern)"></rect>
        </svg>

        <div id="sliderContainer" class="relative w-full h-full flex transition-transform duration-700 ease-in-out">
            <% banners.forEach((banner, idx) => { %>
            <div class="w-full h-full flex-shrink-0 relative">
                <img src="<%= banner.image %>" class="w-full h-full object-cover opacity-[0.28] mix-blend-luminosity" />
                <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6 pt-16 z-10">
                    <div class="max-w-4xl">
                        <div class="inline-flex items-center gap-2 bg-white/[0.06] px-5 py-1.5 rounded-full text-[var(--gold-soft)] text-xs font-bold tracking-[0.18em] uppercase border border-white/10 mb-6">
                            <i class="fas fa-star text-[var(--gold)]"></i> Penyelenggara Resmi Umroh &amp; Haji Khusus
                        </div>
                        <h1 class="hero-title font-display text-4xl md:text-6xl lg:text-7xl font-medium text-[var(--sand)] leading-[1.08] tracking-tight">
                            <span>Ibadah</span> <span class="accent">Berkah,</span><br class="hidden md:block">
                            <span>Perjalanan</span> <span>Tenang</span>
                        </h1>
                        <p class="text-white/65 text-base md:text-lg max-w-xl mx-auto mt-6 font-light leading-relaxed">
                            Melayani Umroh &amp; Haji Khusus dengan pembimbing profesional, jadwal terjaga, dan fasilitas terbaik di Tanah Suci.
                        </p>
                        <div class="flex flex-wrap items-center justify-center gap-4 mt-9">
                            <a href="#paket" class="inline-flex items-center gap-2 bg-[var(--gold)] text-[#2B1B10] px-8 py-3.5 rounded-full font-bold shadow-2xl shadow-black/20 hover:bg-[var(--gold-soft)] hover:scale-105 transition-all duration-300">
                                <i class="fas fa-calendar-check"></i> Lihat Paket
                            </a>
                            <a href="#kontak" class="inline-flex items-center gap-2 bg-white/[0.06] text-white border border-white/15 px-8 py-3.5 rounded-full font-semibold hover:bg-white/[0.12] transition-all duration-300">
                                <i class="fas fa-headset"></i> Konsultasi
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <button onclick="prevSlide()" class="slider-btn absolute left-4 md:left-8 top-1/2 -translate-y-1/2 w-11 h-11 md:w-13 md:h-13 rounded-full bg-black/25 text-white flex items-center justify-center text-lg border border-white/15 transition-all z-20">
            <i class="fas fa-chevron-left"></i>
        </button>
        <button onclick="nextSlide()" class="slider-btn absolute right-4 md:right-8 top-1/2 -translate-y-1/2 w-11 h-11 md:w-13 md:h-13 rounded-full bg-black/25 text-white flex items-center justify-center text-lg border border-white/15 transition-all z-20">
            <i class="fas fa-chevron-right"></i>
        </button>

        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex gap-2 z-20" id="sliderDots">
            <% banners.forEach((_, idx) => { %>
            <button onclick="goToSlide(<%= idx %>)" class="slider-dot w-2.5 h-2.5 rounded-full bg-white/35 transition-all duration-300" data-index="<%= idx %>"></button>
            <% }) %>
        </div>

        <!-- perforated hem, tying hero to the ticket motif used across the page -->
        <div class="perforation absolute bottom-0 left-0 w-full">
            <svg viewBox="0 0 1200 22" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 22 Q30 0 60 22 T120 22 T180 22 T240 22 T300 22 T360 22 T420 22 T480 22 T540 22 T600 22 T660 22 T720 22 T780 22 T840 22 T900 22 T960 22 T1020 22 T1080 22 T1140 22 T1200 22 V22 H0 Z" fill="#F7EFDD"/>
            </svg>
        </div>
    </section>
    <% } %>


    <!-- ════════════════════════════════════════════ -->
    <!--  STAT STRIP                                 -->
    <!-- ════════════════════════════════════════════ -->
    <section class="stat-strip py-10 px-4">
        <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4">
            <div class="text-center reveal px-4">
                <div class="stat-num" data-count="15">0</div>
                <p class="text-xs md:text-sm font-semibold text-white/55 mt-1 tracking-wide">Tahun Pengalaman</p>
            </div>
            <div class="text-center reveal stat-div px-4" style="transition-delay:.08s;">
                <div class="stat-num" data-count="8500">0</div>
                <p class="text-xs md:text-sm font-semibold text-white/55 mt-1 tracking-wide">Jamaah Terlayani</p>
            </div>
            <div class="text-center reveal stat-div px-4" style="transition-delay:.16s;">
                <div class="stat-num" data-count="48">0</div>
                <p class="text-xs md:text-sm font-semibold text-white/55 mt-1 tracking-wide">Paket Tersedia</p>
            </div>
            <div class="text-center reveal stat-div px-4" style="transition-delay:.24s;">
                <div class="stat-num" data-count="100">0</div>
