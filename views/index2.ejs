    <% if (banners && banners.length > 0) { %>
    <section class="relative w-full h-[70vh] md:h-[85vh] overflow-hidden hero-gradient hero-pattern mt-[68px]">
        <!-- Floating decorative shapes -->
        <div class="floating-shapes absolute inset-0 overflow-hidden pointer-events-none">
            <span class="w-64 h-64 -top-20 -left-20 opacity-30"></span>
            <span class="w-96 h-96 bottom-10 -right-20 opacity-20" style="animation-delay:5s;"></span>
            <span class="w-40 h-40 top-1/3 left-1/2 opacity-10" style="animation-delay:10s;"></span>
        </div>

        <div id="sliderContainer" class="relative w-full h-full flex transition-transform duration-700 ease-in-out">
            <% banners.forEach((banner, idx) => { %>
            <div class="w-full h-full flex-shrink-0 relative">
                <img src="<%= banner.image %>" class="w-full h-full object-cover opacity-70 mix-blend-overlay" />
                <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6 z-10">
                    <div class="max-w-4xl">
                        <div class="inline-block bg-white/10 backdrop-blur-sm px-5 py-1.5 rounded-full text-white/80 text-sm font-medium border border-white/10 mb-5">
                            <i class="fas fa-star text-yellow-400 mr-1.5"></i> Perjalanan Ibadah Berkah
                        </div>
                        <h1 class="hero-title text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] tracking-tight drop-shadow-2xl">
                            <span>I</span><span>b</span><span>a</span><span>d</span><span>a</span><span>h</span>
                            <span class="text-emerald-300">B</span><span>e</span><span>r</span><span>k</span><span>a</span><span>h</span>
                        </h1>
                        <p class="text-white/80 text-base md:text-xl max-w-2xl mx-auto mt-4 font-light leading-relaxed drop-shadow-md">
                            Melayani Umroh &amp; Haji Khusus dengan pembimbing profesional dan fasilitas terbaik.
                        </p>
                        <div class="flex flex-wrap items-center justify-center gap-4 mt-8">
                            <a href="#paket" class="inline-flex items-center gap-2 bg-white text-green-800 px-8 py-3.5 rounded-full font-bold shadow-2xl shadow-black/20 hover:scale-105 transition-all duration-300">
                                <i class="fas fa-calendar-check"></i> Lihat Paket
                            </a>
                            <a href="#kontak" class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white border border-white/20 px-8 py-3.5 rounded-full font-semibold hover:bg-white/20 transition-all duration-300">
                                <i class="fas fa-headset"></i> Konsultasi
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <!-- Slider Controls -->
        <button onclick="prevSlide()" class="slider-btn absolute left-4 md:left-8 top-1/2 -translate-y-1/2 w-11 h-11 md:w-14 md:h-14 rounded-full bg-black/30 backdrop-blur-sm text-white flex items-center justify-center text-lg md:text-2xl border border-white/10 hover:bg-green-600 transition-all z-20 opacity-0 hover:opacity-100 focus:opacity-100 group-hover:opacity-100">
            <i class="fas fa-chevron-left"></i>
        </button>
        <button onclick="nextSlide()" class="slider-btn absolute right-4 md:right-8 top-1/2 -translate-y-1/2 w-11 h-11 md:w-14 md:h-14 rounded-full bg-black/30 backdrop-blur-sm text-white flex items-center justify-center text-lg md:text-2xl border border-white/10 hover:bg-green-600 transition-all z-20 opacity-0 hover:opacity-100 focus:opacity-100 group-hover:opacity-100">
            <i class="fas fa-chevron-right"></i>
        </button>

        <!-- Dots -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-2 z-20" id="sliderDots">
            <% banners.forEach((_, idx) => { %>
            <button onclick="goToSlide(<%= idx %>)" class="slider-dot w-2.5 h-2.5 rounded-full bg-white/40 transition-all duration-300" data-index="<%= idx %>"></button>
            <% }) %>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-1 text-white/40 text-xs font-light tracking-widest animate-bounce">
            <span>GULIR</span>
            <i class="fas fa-chevron-down text-sm"></i>
        </div>
    </section>
    <% } %>


